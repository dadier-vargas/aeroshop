# ============================================================
# AeroShop - Variables de Entorno (MODO PRUEBA / SANDBOX)
# ============================================================
# NUNCA subas claves reales a Git. Usa solo claves de PRUEBA (test).
# Obtén tus claves en: https://dashboard.stripe.com/test/apikeys

# Clave secreta del servidor (NUNCA exponer en frontend)
STRIPE_SECRET_KEY=sk_test_COLOCA_TU_CLAVE_SECRETA_AQUI

# Clave pública (sí se puede usar en frontend con Stripe.js)
STRIPE_PUBLISHABLE_KEY=pk_test_COLOCA_TU_CLAVE_PUBLICA_AQUI

# Secreto para validar webhooks (obtenlo en Stripe Dashboard > Developers > Webhooks)
# Para desarrollo local usa Stripe CLI: stripe login && stripe listen --forward-to localhost:5000/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_COLOCA_TU_WEBHOOK_SECRET_AQUI

# JWT - OBLIGATORIO en producción (mínimo 32 caracteres aleatorios)
JWT_SECRET=cambia-este-secreto-por-uno-largo-y-aleatorio-en-produccion

# Sesión OAuth (Passport) — puede ser igual a JWT_SECRET en desarrollo
SESSION_SECRET=cambia-este-secreto-de-sesion-oauth

# Firma del parámetro state anti-CSRF (opcional; usa SESSION_SECRET si se omite)
OAUTH_STATE_SECRET=cambia-este-secreto-para-state-oauth

# Orígenes permitidos para CORS (separados por coma)
CORS_ORIGINS=http://localhost:5000

# Puerto del servidor (opcional)
PORT=5000

# Entorno: development | production
NODE_ENV=development

# URL pública del sitio (producción)
# PUBLIC_URL=https://tu-dominio.com
# FRONTEND_URL=https://tu-dominio.com

# Base URL para callbacks OAuth (debe coincidir con Google/Apple Console)
# En local: http://localhost:5000
OAUTH_CALLBACK_BASE_URL=http://localhost:5000

# --- Producción (ver .env.production.example) ---
# HOST=0.0.0.0
# TRUST_PROXY=true
# API_BASE_PATH=/api
# SEED_DEMO_USERS=false
# ALLOW_SIMULATED_PAYMENTS=false

# Credenciales demo (solo desarrollo; cámbialas en producción)
# Admin:   admin@ecommerce.com
# Cliente: cliente@ecommerce.com
SEED_ADMIN_PASSWORD=ChgMe!AeroAdmin9
SEED_CLIENT_PASSWORD=ChgMe!Cliente9

# Solo para desarrollo: habilitar pagos simulados (PSE/wallet) en producción
# ALLOW_SIMULATED_PAYMENTS=false

# ============================================================
# OAuth — Google (https://console.cloud.google.com/apis/credentials)
# ============================================================
# 1. Crea "OAuth 2.0 Client ID" tipo "Web application"
# 2. Authorized JavaScript origins: http://localhost:5000 (y tu dominio en prod)
# 3. Authorized redirect URIs: http://localhost:5000/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ============================================================
# OAuth — Apple (https://developer.apple.com/account/resources/identifiers/list/serviceId)
# ============================================================
# 1. Crea un Services ID (APPLE_CLIENT_ID)
# 2. Configura "Sign in with Apple" con Return URL:
#    http://localhost:5000/auth/apple/callback
# 3. Crea una Key (.p8) y copia Team ID, Key ID y contenido de la clave
APPLE_CLIENT_ID=your-apple-service-id
APPLE_TEAM_ID=your-apple-team-id
APPLE_KEY_ID=your-apple-key-id
# Pega la clave .p8 en una sola línea reemplazando saltos con \n
APPLE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nYOUR_KEY_CONTENT\n-----END PRIVATE KEY-----