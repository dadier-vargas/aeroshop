# ============================================================
# AeroShop - Plantilla de PRODUCCIÓN
# ============================================================
# 1. Copia este archivo:  copy .env.production.example .env
# 2. Completa los valores marcados con CAMBIAR
# 3. Genera JWT: node scripts/setup-production-env.js --write
# 4. Valida:      npm run validate:prod
# 5. Inicia:      npm run start:prod

NODE_ENV=production
HOST=0.0.0.0
PORT=5000
TRUST_PROXY=true

# URL pública con HTTPS (sin barra final)
PUBLIC_URL=https://tu-dominio.com

# Orígenes CORS permitidos (normalmente igual a PUBLIC_URL)
CORS_ORIGINS=https://tu-dominio.com

# Ruta base de la API (monolito Express: dejar /api)
API_BASE_PATH=/api

# JWT — generar con: node scripts/setup-production-env.js
JWT_SECRET=CAMBIAR-genera-un-secreto-largo-unico

# Stripe LIVE (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_live_CAMBIAR
STRIPE_PUBLISHABLE_KEY=pk_live_CAMBIAR
STRIPE_WEBHOOK_SECRET=whsec_CAMBIAR

# Seguridad — mantener en false en producción
ALLOW_SIMULATED_PAYMENTS=false
SEED_DEMO_USERS=false

# No crear usuarios demo en producción
# Si necesitas un admin inicial, regístralo manualmente o usa SEED_DEMO_USERS=true solo en el primer despliegue